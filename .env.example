# Copy this file to .env.local and fill in real keys.
# .env.local is gitignored; .env.example is committed as a template.
# Never put real secrets in this file.

# OpenAI: chat (gpt-4o) AND every auditor call (extractor, 3 verifier subagents,
# dehallucinator) — all use gpt-4o-mini. Get a key at:
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini: chat only (gemini-1.5-pro / gemini-1.5-flash). Never used by
# the auditor — keeping the auditor fixed to OpenAI is what makes the
# chat-model comparison meaningful. Get a key at:
# https://aistudio.google.com/apikey
# NOTE: this is a Google API key, NOT an OAuth client ID URL.
GEMINI_API_KEY=

# Tavily: web search for evidence retrieval inside each verifier subagent.
# Free tier is plenty for development. Get a key at:
# https://tavily.com
TAVILY_API_KEY=
